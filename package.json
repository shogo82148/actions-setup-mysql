{
  "name": "actions-setup-mysql",
  "version": "0.0.0",
  "private": true,
  "description": "Setup MySQL GitHub Action",
  "main": "dist/setup-mysql.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npx eslint .",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shogo82148/actions-setup-mysql.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/tool-cache": "^4.0.0",
    "semver": "^7.7.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/eslint__js": "^8.42.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/semver": "^7.7.1",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "jest-circus": "^30.0.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "ts-jest": "^29.4.9",
    "ts-jest-resolver": "^2.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
